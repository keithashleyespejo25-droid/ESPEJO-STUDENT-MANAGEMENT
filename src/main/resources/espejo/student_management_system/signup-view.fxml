<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" alignment="CENTER"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="espejo.student_management_system.controller.SignUpController"
      style="-fx-background-color: linear-gradient(to bottom, #ffe4ec, #fff0f6);">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24" />
    </padding>

    <children>
        <Label text="Sign Up"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #b3125a;" />

        <TextField fx:id="usernameField"
                   promptText="Username"
                   maxWidth="260"
                   style="-fx-background-color: white; -fx-border-color: #ffb6c1; -fx-border-radius: 10; -fx-background-radius: 10;" />

        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       maxWidth="260"
                       style="-fx-background-color: white; -fx-border-color: #ffb6c1; -fx-border-radius: 10; -fx-background-radius: 10;" />

        <PasswordField fx:id="confirmPasswordField"
                       promptText="Confirm Password"
                       maxWidth="260"
                       style="-fx-background-color: white; -fx-border-color: #ffb6c1; -fx-border-radius: 10; -fx-background-radius: 10;" />

        <Button text="Create Account"
                onAction="#handleCreateAccount"
                maxWidth="260"
                style="-fx-background-color: #ff4f93; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />

        <Button text="Back to Login"
                onAction="#handleBackToLogin"
                maxWidth="260"
                style="-fx-background-color: #ff9fc6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />
    </children>
</VBox>