<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="espejo.student_management_system.controller.StudentController" style="-fx-background-color: linear-gradient(to bottom, #ffe4ec, #fff0f6);">

    <padding>
        <Insets top="18" right="18" bottom="18" left="18" />
    </padding>

    <children>
        <Label text="PUPSRC Student Management System" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #b3125a;" />

        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints percentWidth="16" />
                <ColumnConstraints percentWidth="34" />
                <ColumnConstraints percentWidth="16" />
                <ColumnConstraints percentWidth="34" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>

            <Label text="ID" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-text-fill: #c2185b;" />
            <TextField fx:id="idField" editable="false" promptText="Auto-generated"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"
                       style="-fx-background-color: #ffffff; -fx-border-color: #ffb6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

            <Label text="Student No." GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-text-fill: #c2185b;" />
            <TextField fx:id="studentNumberField" promptText="2026-0001"
                       GridPane.rowIndex="0" GridPane.columnIndex="3"
                       style="-fx-background-color: #ffffff; -fx-border-color: #ffb6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

            <Label text="First Name" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-text-fill: #c2185b;" />
            <TextField fx:id="firstNameField" promptText="Juan"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"
                       style="-fx-background-color: #ffffff; -fx-border-color: #ffb6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

            <Label text="Last Name" GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-text-fill: #c2185b;" />
            <TextField fx:id="lastNameField" promptText="Dela Cruz"
                       GridPane.rowIndex="1" GridPane.columnIndex="3"
                       style="-fx-background-color: #ffffff; -fx-border-color: #ffb6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

            <Label text="Course" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-text-fill: #c2185b;" />
            <TextField fx:id="courseField" promptText="BSIT"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"
                       style="-fx-background-color: #ffffff; -fx-border-color: #ffb6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

            <Label text="Year Level" GridPane.rowIndex="2" GridPane.columnIndex="2" style="-fx-text-fill: #c2185b;" />
            <TextField fx:id="yearLevelField" promptText="1"
                       GridPane.rowIndex="2" GridPane.columnIndex="3"
                       style="-fx-background-color: #ffffff; -fx-border-color: #ffb6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

            <Label text="Email" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-text-fill: #c2185b;" />
            <TextField fx:id="emailField" promptText="student@example.com"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"
                       style="-fx-background-color: #ffffff; -fx-border-color: #ffb6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />

            <Label text="Phone" GridPane.rowIndex="3" GridPane.columnIndex="2" style="-fx-text-fill: #c2185b;" />
            <TextField fx:id="phoneField" promptText="09xxxxxxxxx"
                       GridPane.rowIndex="3" GridPane.columnIndex="3"
                       style="-fx-background-color: #ffffff; -fx-border-color: #ffb6c1; -fx-border-radius: 8; -fx-background-radius: 8;" />
        </GridPane>

        <HBox spacing="10">
            <children>
                <Button text="Add" onAction="#handleAdd"
                        style="-fx-background-color: #ff4f93; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />

                <Button text="Update" onAction="#handleUpdate"
                        style="-fx-background-color: #ff7fb0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />

                <Button text="Delete" onAction="#handleDelete"
                        style="-fx-background-color: #ff2f6d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />

                <Button text="Clear" onAction="#handleClear"
                        style="-fx-background-color: #ff9fc6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />
            </children>
        </HBox>

        <TableView fx:id="studentTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: #ffffff; -fx-border-color: #ffb6c1; -fx-border-radius: 10;">

            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="70" />
                <TableColumn fx:id="studentNumberColumn" text="Student No." prefWidth="130" />
                <TableColumn fx:id="firstNameColumn" text="First Name" prefWidth="140" />
                <TableColumn fx:id="lastNameColumn" text="Last Name" prefWidth="140" />
                <TableColumn fx:id="courseColumn" text="Course" prefWidth="120" />
                <TableColumn fx:id="yearLevelColumn" text="Year" prefWidth="70" />
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="220" />
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="140" />
            </columns>
        </TableView>

        <Pagination fx:id="studentPagination" pageCount="1" maxPageIndicatorCount="5"
                    style="-fx-base: #ffb6c1; -fx-background-color: transparent;" />

    </children>
</VBox>